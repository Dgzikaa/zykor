# ====================================================
# Zykor — .gitignore
# ====================================================

# --- Dependências ---
node_modules/
/.pnp
.pnp.js
**/node_modules/.cache/

# --- Next.js / build ---
frontend/.next/
frontend/out/
frontend/build/
.next/
out/
/build
/dist
dist/
build/
.turbo/

# --- Testing / coverage ---
/coverage
**/coverage/
test-results/
.jest-cache/

# --- TypeScript / cache ---
*.tsbuildinfo
**/*.tsbuildinfo
**/tsconfig.tsbuildinfo
next-env.d.ts
.cache/
**/.cache/
**/.eslintcache

# --- Env e segredos ---
.env
.env.local
.env.development.local
.env.test.local
.env.production.local
.env*.local
frontend/.env
frontend/.env.local
*.pem
*.key
*.crt

# --- Credenciais externas (NEVER COMMIT) ---
**/credentials_deboche_ordinario.json
credentials_deboche_ordinario.json
**/google-service-account.json
google-service-account.json
exemplo_teste/
# Inputs de cadastro de credencial cifrada (texto puro temporário — DELETE após rodar)
scripts/*.local.json
credenciais-inter.local.json

# --- Vercel / Supabase ---
.vercel
**/.vercel/
supabase/.branches
supabase/.temp

# --- Logs ---
logs/
**/logs/
*.log
**/*.log
npm-debug.log*
yarn-debug.log*
yarn-error.log*

# --- Temp / sentry ---
*.tmp
*.temp
**/temp/
**/tmp/
**/.temp/
**/.tmp/
**/.sentry/

# --- Large generated ---
**/*.min.js
**/*.min.css
**/*.map

# --- Python ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
env/
venv/
ENV/

# --- IDE ---
.vscode/
.idea/
**/.idea/
**/.vscode/settings.json.bak
*.swp
*.swo

# --- OS ---
.DS_Store
Thumbs.db

# --- NPM cache ---
**/.npm-cache/
frontend/.npm-cache/

# --- Package manager backups ---
**/package-lock.json.bak
**/yarn.lock.bak
**/pnpm-lock.yaml.bak

# --- Scripts / dados temporários ---
scripts/progresso-importacao.json

# --- Setup pessoal de agentes IA (não vai pro repo) ---
.agent/
.api/

# --- Lixo histórico da raiz (NÃO recriar) ---
# Mensagens de commit avulsas, dumps de debug, MDs históricos:
# tudo isso pertence a docs/historico/, não à raiz.
/commit_*.txt
/temp_*.json
/temp_*.txt
/*.bak
/RELATORIO_*.md
/ANALISE-*.md
/BUGS_*.md
/FIX_*.md
/LIMPEZA-*.md
/RESUMO-*.md
