{
  "env": {
    "browser": true,
    "es2021": true,
    "node": true,
    "jest": true
  },
  "extends": [
    "next/core-web-vitals",
    "eslint:recommended",
    "plugin:jsx-a11y/recommended"
  ],
  "parser": "@typescript-eslint/parser",
  "parserOptions": {
    "ecmaVersion": "latest",
    "sourceType": "module"
  },
  "globals": {
    "React": "readonly",
    "NodeJS": "readonly",
    "RequestInit": "readonly",
    "EventListener": "readonly",
    "AddEventListenerOptions": "readonly",
    "EventListenerOptions": "readonly",
    "ShareData": "readonly",
    "NotificationPermission": "readonly",
    "NotificationOptions": "readonly",
    "PublicKeyCredential": "readonly",
    "PublicKeyCredentialCreationOptions": "readonly",
    "AuthenticatorAttestationResponse": "readonly",
    "PublicKeyCredentialRequestOptions": "readonly",
    "AuthenticatorAssertionResponse": "readonly",
    "ChecklistTemplate": "readonly",
    "Setor": "readonly",
    "NotificationStatus": "readonly",
    "useState": "readonly",
    "useEffect": "readonly",
    "useCallback": "readonly",
    "useMemo": "readonly",
    "useRouter": "readonly"
  },
  "rules": {
    "no-console": "off",
    "no-unused-vars": "off",
    "no-useless-escape": "off",
    "no-undef": "error",
    "no-redeclare": "error",
    "no-case-declarations": "error",
    "no-empty": "error",
    "jsx-a11y/anchor-is-valid": "warn",
    "jsx-a11y/no-static-element-interactions": "warn",
    "jsx-a11y/click-events-have-key-events": "warn",
    "jsx-a11y/no-autofocus": "error",
    "jsx-a11y/label-has-associated-control": [
      "warn",
      {
        "assert": "either",
        "depth": 3
      }
    ],
    "@next/next/no-img-element": "warn",
    "import/no-anonymous-default-export": "warn"
  }
}
