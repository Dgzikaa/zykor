# ==============================================================================
# Zykor — variáveis de ambiente (frontend / Next.js)
# ------------------------------------------------------------------------------
# Copie para .env.local e preencha. NUNCA commitar segredos reais.
# NEXT_PUBLIC_* são expostas ao navegador (só coisas públicas ali).
# ==============================================================================

# ---------- Supabase (core) ----------
NEXT_PUBLIC_SUPABASE_URL=https://<projeto>.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=sb_publishable_...   # publishable (substitui a anon)
SUPABASE_SERVICE_ROLE_KEY=sb_secret_...            # secret (substitui service_role — bypassa RLS, NUNCA no cliente)
SUPABASE_URL=https://<projeto>.supabase.co         # usado por alguns scripts/edge
# SERVICE_ROLE_KEY / SUPABASE_SERVICE_KEY = aliases legados do secret (manter só se usados)
SUPABASE_METRICS_SECRET=                            # token do Metrics API (painel de saúde)

# ---------- Autenticação (JWT próprio do Zykor) ----------
JWT_SECRET=<segredo forte>                          # assina o auth_token (login). Separado das chaves Supabase.
JWT_REFRESH_SECRET=<segredo forte>                  # assina o refresh_token
AUTH_VERBOSE_LOGS=false                              # true só p/ debug (loga email — nunca em prod)

# ---------- Cron / segredos de sistema ----------
CRON_SECRET=<segredo forte>                          # Bearer dos crons (Vercel + pg_cron → /api)
CREDENTIALS_MASTER_KEY=<32 bytes base64>             # envelope encryption das credenciais bancárias

# ---------- Banco Inter (PIX / boletos) ----------
INTER_CERT_BASE64=                                   # certificado mTLS (base64)
INTER_KEY_BASE64=                                    # chave mTLS (base64)
INTER_CERT=                                          # alternativa em arquivo
INTER_KEY=
INTER_WEBHOOK_TOKEN=                                 # valida o webhook PIX do Inter
INTER_WEBHOOK_PUBLIC_URL=
DISCORD_INTER_WEBHOOK_URL=                           # alerta de PIX no Discord

# ---------- Pluggy (Open Finance — opcional) ----------
PLUGGY_CLIENT_ID=
PLUGGY_CLIENT_SECRET=

# ---------- Google (Sheets / OAuth / Service Account) ----------
GOOGLE_SHEETS_API_KEY=                               # leitura de planilhas (rotacionar se vazar)
GOOGLE_SERVICE_ACCOUNT_KEY=                          # JSON da service account (import RH/planilhas)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ---------- Meta / Instagram ----------
INSTAGRAM_APP_ID=
INSTAGRAM_APP_SECRET=
META_OAUTH_REDIRECT_URI=
META_WEBHOOK_VERIFY_TOKEN=
WEBHOOK_VERIFY_TOKEN=

# ---------- WhatsApp (Umbler / Evolution) ----------
UMBLER_API_TOKEN=                                    # segredo — token da API Umbler Talk (conta inteira)
UMBLER_NOTIF_FROM=                                   # opcional — nº do canal "Zykor Notificações" (fallback 5561998584761)
UMBLER_NOTIF_ORG=                                    # opcional — organizationId Umbler (fallback aDjKophL8jEd_D8m)
UMBLER_NOTIF_TEMPLATE_ID=                            # opcional — TemplateId do zykor_alerta (fallback akvdZtIp0v4fiRGQ)
EVOLUTION_API_URL=
EVOLUTION_API_KEY=                                   # segredo — só via env (rotacionar se vazar)
EVOLUTION_INSTANCE_NAME=
WHATSAPP_SIMULATION_MODE=true                        # true = não envia de verdade

# ---------- E-mail ----------
RESEND_API_KEY=                                      # envio transacional (reset de senha, etc.)
SMTP_HOST=
SMTP_PORT=
SMTP_USER=
SMTP_PASS=
ALERT_EMAIL=                                         # destino de alertas internos

# ---------- IA ----------
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=

# ---------- Monitoramento / alertas ----------
NEXT_PUBLIC_SENTRY_DSN=
DISCORD_WEBHOOK_URL=                                 # alertas gerais (Zykor usa Discord, não WhatsApp)
SLACK_WEBHOOK_URL=
NEXT_PUBLIC_GRAFANA_DASHBOARD_URL=
NEXT_PUBLIC_ERROR_MONITORING_URL=

# ---------- Web Push (notificação no celular) ----------
NEXT_PUBLIC_VAPID_PUBLIC_KEY=
VAPID_PRIVATE_KEY=

# ---------- App / público ----------
NEXT_PUBLIC_APP_URL=https://zykor.com.br
NEXT_PUBLIC_SITE_URL=https://zykor.com.br
NEXT_PUBLIC_NPS_LINK=
NEXT_PUBLIC_APP_VERSION=
NEXT_PUBLIC_VERBOSE_LOGS=false
# Desempenho: v1=/api/gestao/desempenho (recalcula) · v2=/api/estrategico/desempenho-v2 (gold puro)
NEXT_PUBLIC_DESEMPENHO_API_VERSION=v1

# ---------- Runtime (setadas automaticamente pela Vercel — não preencher) ----------
# NODE_ENV, TZ, NEXT_RUNTIME, VERCEL_*, NEXT_PUBLIC_VERCEL_GIT_COMMIT_SHA, NEXT_PUBLIC_BUILD_ID
