# ============================================
# ZYKOR - Variáveis de Ambiente
# ============================================
# 
# INSTRUÇÕES:
# 1. Copie este arquivo para .env.local
# 2. Preencha TODOS os valores obrigatórios
# 3. NUNCA commite o arquivo .env.local
# 4. Para produção, configure no Vercel Dashboard
#
# ============================================

# ============================================
# SUPABASE (OBRIGATÓRIO)
# ============================================
# Obtenha em: https://supabase.com/dashboard/project/[seu-projeto]/settings/api
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=

# ============================================
# APLICAÇÃO
# ============================================
# URL base da aplicação (para webhooks e callbacks)
NEXT_PUBLIC_APP_URL=http://localhost:3000

# Secret para autenticação de cron jobs
CRON_SECRET=

# JWT Secret para autenticação
JWT_SECRET=

# ============================================
# INTEGRAÇÕES EXTERNAS (OPCIONAL)
# ============================================

# Google Gemini AI
GEMINI_API_KEY=

# Discord Webhooks
DISCORD_WEBHOOK_URL=
DISCORD_WEBHOOK_CRITICAL=
DISCORD_WEBHOOK_LOGS=

# ContaHub
CONTAHUB_API_KEY=
CONTAHUB_BASE_URL=https://api.contahub.com

# NIBO
NIBO_API_KEY=
NIBO_BASE_URL=https://api.nibo.com.br

# Sympla
SYMPLA_TOKEN=

# Yuzer
YUZER_API_KEY=

# GetIn
GETIN_API_KEY=

# ============================================
# DESENVOLVIMENTO (OPCIONAL)
# ============================================
# Habilitar logs de debug
DEBUG_LOGIN=false

# Link da pesquisa NPS
NEXT_PUBLIC_NPS_LINK=https://forms.gle/seu-link-aqui
